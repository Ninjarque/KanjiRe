# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# PyInstaller release output (regenerated by scripts/build_release.py)
build/
dist/
*.spec

# KanjiRe runtime / generated artifacts
kanjire/data/user_state.json
kanjire/data/stats.db
kanjire/data/kanjire.db-wal
kanjire/data/kanjire.db-shm
tests/_shots/

# Update signing key must NEVER be committed (it lives in ~/.kanjire_keys,
# outside the repo — this is just a belt-and-suspenders guard).
*update_ed25519*
.kanjire_keys/

# Downloaded corpora text (regenerate via scripts/fetch_sample_corpus.py)
corpora/*.txt

# OS
Thumbs.db
.DS_Store

# updater diagnostics (written next to the user save file)
update.log
